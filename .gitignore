# Если .gitignore ещё нет или он в src/ — создайте в корне:
@'
# Environment & Secrets
.env
*.env
.env.local
*.secret
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Trading-specific
logs/
backtest_results/private_*.json
keys/
*.log

# OS & IDE
.DS_Store
Thumbs.db
.vscode/*.json
!.vscode/extensions.json
'@ | Out-File -FilePath ".gitignore" -Encoding utf8